        <mxCell id="CtcYVQr6jMdZxorEDW9T-20" value="/auth/password/check&#xa;проверка пароля&#xa;&#xa;Ввести пароль&#xa;кнопка отправить&#xa;isLockedPass: false&#xa;timeLockedPass: null,&#xa;&#xa;кнопка зарегистрироваться  (переход на регистрацию)&#xa;&#xa;&#xa;отправляем пароль&#xa;&#xa;нужно еще страницу создать&#xa;если пароль не верный&#xa;&#xa;приходит&#xa;1. вариант приходят токены и редирект в защищенные папки app/(protected)&#xa;2. вариант приходит статус protection true&#xa;то редирект на auth/secret/check&#xa;&#xa;Если пользоватеь подтвердил почту или номер &#xa;то здесь будет компонент по востановлению пароля&#xa;&lt;RecoverPassword&gt;" style="fillColor=#d5e8d4;strokeColor=#82b366;rounded=0;glass=1;verticalAlign=top;whiteSpace=wrap;" parent="1" vertex="1">
