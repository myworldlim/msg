        <mxCell id="CtcYVQr6jMdZxorEDW9T-23" value="&lt;span style=&quot;background-color: transparent; color: rgb(51, 51, 51); text-align: left;&quot;&gt;/auth/&lt;/span&gt;password/register&lt;div&gt;&lt;div&gt;&lt;div&gt;проверка на одинаковый пароль&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Создать пароль&lt;div&gt;Подтвердить пароль&lt;/div&gt;&lt;/div&gt;&lt;div&gt;кнопка отправить&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;кнопка войти (переход войти)&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;отправляется&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left; color: rgb(51, 51, 51);&quot;&gt;&lt;span style=&quot;color: rgb(51, 51, 51);&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap; background-color: transparent; color: rgb(0, 0, 0);&quot;&gt;identifier=номер или почта&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left; color: rgb(51, 51, 51);&quot;&gt;&lt;span style=&quot;color: rgb(51, 51, 51);&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap; background-color: transparent; color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;text-align: center; text-wrap-mode: wrap;&quot;&gt;exists = false (означает что нужно записать пароль)&lt;br&gt;введенный пароль&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left; color: rgb(51, 51, 51);&quot;&gt;&lt;span style=&quot;color: rgb(51, 51, 51);&quot;&gt;&lt;span style=&quot;text-wrap-mode: nowrap; background-color: transparent; color: rgb(0, 0, 0);&quot;&gt;protection отправляем есть галочка или ее нет&lt;span style=&quot;text-align: center; text-wrap-mode: wrap;&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;приходит&lt;/div&gt;&lt;div&gt;password false / true&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;значение из таблицы protection&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;если пришли токены в ответе&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;session_token refresh_token&lt;/span&gt;&lt;/div&gt;&lt;div&gt;то редирект в папку app/(protected)&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;checkbox на дополнительную защиту (&lt;span style=&quot;text-align: left; text-wrap-mode: nowrap; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;protection)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Privacy Policy&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Terms of Use&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=0;glass=1;verticalAlign=top;" parent="1" vertex="1">
