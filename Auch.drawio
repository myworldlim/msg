        <mxCell id="CtcYVQr6jMdZxorEDW9T-29" value="Бекенд&lt;div&gt;/&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;auth&lt;/span&gt;/&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;open&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;проверка авторизации&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;пришел json&lt;br&gt;&lt;span style=&quot;font-family: &amp;quot;Segoe WPC&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 13px; text-align: left;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 255);&quot;&gt;{ identifier: string, type: &#39;email&#39; | &#39;number&#39; }&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;дополнительная проверка почты или номера&lt;br&gt;если валидный то переходим к следующему этапу&lt;br&gt;делаем запрос в базу данных&amp;nbsp;&lt;/div&gt;&lt;div&gt;таблицу users_id по значению type email / number в соответсвующем поле&lt;/div&gt;&lt;div&gt;таблицы это user_number / user_email проверяем&lt;br&gt;&lt;/div&gt;&lt;div&gt;если пользователь существует &quot;exists&quot;: true,&lt;/div&gt;&lt;div&gt;далее берем значения из поля user_uid (&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;62EgX8gtH5fqhBQyIWnL)&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;и&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;делаем запрос в другую таблицу guid с полями&lt;/div&gt;&lt;div&gt;user_uid&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;62EgX8gtH5fqhBQyIWnL)&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;и поле guid (порядковый номер)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;далее по guid переходим в таблицу&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;blocked&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;и проверяем значение поля blocked_status в значениях&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;false или true&lt;/span&gt;&amp;nbsp;или пользователя нет в таблице&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;БД&lt;/div&gt;&lt;div&gt;users_id&lt;/div&gt;&lt;/div&gt;&lt;div&gt;guid&lt;/div&gt;&lt;div&gt;blocked&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;возвращаем ответ json&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&quot;exists&quot;: false / true&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;blocked false / true&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;user_uid (&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;62EgX8gtH5fqhBQyIWnL)&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=0;glass=1;" parent="1" vertex="1">
