        <mxCell id="SQmltQD4dl8pnAUpSeKT-37" value="Бекенд&lt;div&gt;/&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;auth&lt;/span&gt;/&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;auth_open&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;проверка авторизации&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;дополнительная проверка почты или номера&lt;/div&gt;&lt;div&gt;если пользователь существует &quot;exists&quot;: true&lt;/div&gt;&lt;div&gt;то еще проверяем его в blocked,&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;blocked false или true&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;если не существует такого пользователя то возвращаем &quot;exists&quot;: false и blocked false&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;БД&lt;/div&gt;&lt;div&gt;users_id&lt;/div&gt;&lt;/div&gt;&lt;div&gt;blocked&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;возвращаем ответ&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&quot;exists&quot;: false или true&lt;/span&gt;&lt;div&gt;blocked false или true&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=0;glass=1;" parent="1" vertex="1">
