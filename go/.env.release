# /.env.release
# --- Основные настройки ---
APP_ENV=release             # Окружение
APP_PORT=443                    # Порт HTTP-сервера HTTPS порт
WS_PORT=443                     # Порт WebSocket-сервера (HTTPS) Тот же порт для WSS

# --- Домены ---
FRONTEND_ORIGIN=https://chitchat.com  # Продакшен домен фронтенда для CORS
BACKEND_ORIGIN=https://api.chitchat.com  # Продакшен домен бэкенда (API)
WS_ORIGIN=wss://api.chitchat.com       # Продакшен домен WebSocket

# --- API Настройки ---
# API_PREFIX=/                        # В продакшене API на корневом пути

# --- Настройки базы данных ---
DB_USER=postgres           # Пользователь БД
DB_PASSWORD=toor  # Сложный пароль
DB_HOST=localhost   # Хост БД (например, RDS)
DB_PORT=5432               # Порт БД
DB_NAME=ch           # Имя БД
DB_SSLMODE=require         # TLS для production
DB_MAX_CONNS=50            # Максимальное количество соединений с базой данных
DB_MIN_CONNS=5             # Минимальное количество соединений с базой данных
# DB_SSLCERT=/path/to/cert.pem  # Путь к сертификату, если требуется
# DB_SSLKEY=/path/to/key.pem    # Путь к ключу
# DB_SSLROOTCERT=/path/to/ca.pem  # Путь к корневому сертификату

# --- JWT токен ---
JWT_SECRET=7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8  # Уникальный секрет (64+ символов)

# --- Настройки MinIO (S3-хранилище файлов) ---
# MINIO_ENDPOINT=minio.yourapp.com
# MINIO_ACCESS_KEY=your_access_key
# MINIO_SECRET_KEY=your_secret_key
# MINIO_USE_SSL=true