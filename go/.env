# /.env
# --- Основные настройки ---
APP_ENV=release             # Окружение (local, production)
APP_PORT=8181               # Порт HTTP-сервера
WS_PORT=8182                # Порт WebSocket-сервера

# --- Домены ---
FRONTEND_ORIGIN=http://localhost:3000  # Домен фронтенда для CORS
BACKEND_ORIGIN=http://localhost:8181   # Домен бэкенда (для документации)
WS_ORIGIN=http://localhost:8182        # Домен WebSocket для проверки Origin

# --- API Настройки ---
# API_PREFIX=/api/                    # ПРЕФИКС API

# --- Настройки базы данных ---
DB_USER=postgres
DB_PASSWORD=toor
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ch
DB_SSLMODE=disable          # В production установите require
DB_MAX_CONNS=50             # Максимальное количество соединений с базой данных
DB_MIN_CONNS=5              # Минимальное количество соединений с базой данных

# --- JWT токен ---
JWT_SECRET=X7k9pLm2qA3sTd4fGhJk5lMn8oPrQw1xYzBcDeFgHiUv9jKlMnOpQrStUvWxYz12

